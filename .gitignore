# macOS
.DS_Store
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# Local data — written by cc-server at runtime, never tracked.
# `runtime/` is the current default (everything lives next to source so
# there's nothing to hunt for). Older default paths kept for back-compat.
runtime/
.claude-code-ui/
claude-ui/

# Environment files
.env
.env.local

# OS / tools
*.log
node_modules/

# Local-only docs / notes — never tracked. Contains operator details
# (paths, ports, tokens) for a specific machine; not shareable.
LOCAL_NOTES.md
JOURNAL-*.md
RETRO-*.md
*.local.md
*.local
secrets/
.secrets/
