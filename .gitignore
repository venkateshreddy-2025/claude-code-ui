# macOS
.DS_Store
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# Local data — these are written by cc-server at runtime, never tracked.
# (CC_DATA_DIR / CC_CWD_ROOT defaults; override paths via env vars.)
.claude-code-ui/
claude-ui/

# Environment files
.env
.env.local

# OS / tools
*.log
node_modules/

# Local-only docs / notes — never tracked. Contains operator details
# (paths, ports, tokens) for a specific machine; not shareable.
LOCAL_NOTES.md
*.local.md
*.local
secrets/
.secrets/
